{
  "name": "trixty.example-addon",
  "displayName": "Hello World Example",
  "version": "0.1.0",
  "description": "An example addon demonstrating the sandboxed extension runtime.",
  "author": "TrixtyAI",
  "main": "index.js",
  "trixty": {
    "capabilities": [
      "ui:register-view",
      "ui:show-message",
      "l10n:register",
      "lang:register",
      "storage:read",
      "storage:write",
      "clipboard:write"
    ]
  },
  "scripts": {
    "start": "node index.js"
  }
}
