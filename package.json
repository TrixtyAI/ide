{
  "name": "trixty-ide",
  "private": true,
  "repository": {
    "url": "https://github.com/TrixtyAI/ide",
    "type": "git"
  },
  "scripts": {
    "build": "turbo run build",
    "desktop": "pnpm --filter @trixty/desktop tauri",
