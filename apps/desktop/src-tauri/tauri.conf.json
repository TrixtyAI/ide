{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TrixtyIDE",
  "version": "0.0.0",
  "identifier": "trixty.ide",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Trixty IDE",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "maximized": false,
        "visible": false,
        "center": true,
        "backgroundColor": "#1e1e1e",
        "devtools": false
      },
      {
        "label": "splashscreen",
        "title": "Trixty IDE",
        "width": 550,
        "height": 350,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "url": "splashscreen.html"
      }
    ],
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost https://raw.githubusercontent.com https://*.sentry.io; script-src 'self' blob: https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost https://*.sentry.io https://o4505655594844160.ingest.us.sentry.io; font-src 'self' data: https://cdn.jsdelivr.net; frame-src *; worker-src 'self' blob:;"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/TrixtyAI/ide/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZENjJGRDY0ODk4MjA5MEQKUldRTkNZS0paUDFpL1RTS3hzZm5RWCt0aUR5ckhYSjU4NUZ1VFUvVzBMZXlVMnVNVkxVZHFBc3IK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
